# Agent mode: "mock" for local development, "databricks" for real agent
AGENT_MODE=mock

# Databricks configuration (only needed when AGENT_MODE=databricks)
DATABRICKS_HOST=https://adb-xxx.azuredatabricks.net
DATABRICKS_SERVING_ENDPOINT=modelator-assistant-endpoint

# Authentication (choose one)
# Option 1: Personal Access Token (for local dev)
DATABRICKS_TOKEN=dapi...

# Option 2: Service Principal (for production)
# DATABRICKS_CLIENT_ID=
# DATABRICKS_CLIENT_SECRET=

# Note: When running as a Databricks App, OBO tokens are
# automatically provided via X-Forwarded-Access-Token header.
